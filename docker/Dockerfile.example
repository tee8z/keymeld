FROM rust:1.88-bookworm AS builder

RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    cmake \
    protobuf-compiler \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY Cargo.toml Cargo.lock ./
COPY crates ./crates
COPY examples ./examples

ENV SQLX_OFFLINE=true
RUN cargo build --release --bin keymeld_demo

FROM debian:bookworm-slim

# Build argument to determine environment (dev, prod)
ARG ENVIRONMENT=dev

RUN apt-get update && apt-get install -y \
    ca-certificates \
    libssl3 \
    curl \
    jq \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -u 1000 -s /bin/bash keymeld

RUN mkdir -p /app/keys /app/config /app/data && \
    chown -R keymeld:keymeld /app

COPY --from=builder /app/target/release/keymeld_demo /usr/local/bin/keymeld_demo

# Copy example config
COPY --chown=keymeld:keymeld docker/config/example.yaml /app/config/config.yaml

RUN chown keymeld:keymeld /usr/local/bin/keymeld_demo && \
    chmod +x /usr/local/bin/keymeld_demo

USER keymeld

WORKDIR /app

ENV RUST_LOG=info,keymeld_demo=debug \
    KEYMELD_CONFIG_PATH=/app/config/config.yaml \
    KEYMELD_KEYS_DIR=/app/keys

VOLUME ["/app/keys", "/app/config", "/app/data"]

COPY --chown=keymeld:keymeld docker/example-entrypoint.sh /usr/local/bin/example-entrypoint.sh
RUN chmod +x /usr/local/bin/example-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/example-entrypoint.sh"]

CMD ["keymeld_demo", "plain", "--config", "/app/config/config.yaml", "--amount", "50000", "--destination", "bcrt1qh3qhjhd7s0p2vu257k3zjtgjxuy5jy0c4pn6wz"]
